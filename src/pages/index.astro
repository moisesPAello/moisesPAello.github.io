---
import Layout from '../layouts/Layout.astro';

const skillGroups = [
  { code: 'A', label: 'Languages', items: ['Python', 'TypeScript', 'JavaScript (ES6+)', 'Java', 'SQL'] },
  { code: 'B', label: 'Frontend', items: ['React', 'HTML5', 'CSS3', 'Responsive design'] },
  { code: 'C', label: 'Backend', items: ['FastAPI', 'REST APIs', 'Async data handling'] },
  { code: 'D', label: 'Data', items: ['pandas', 'Extraction / parsing', 'Normalization', 'Data-quality checks'] },
  { code: 'E', label: 'Databases', items: ['SQL', 'SQLite'] },
  { code: 'F', label: 'DevOps & tools', items: ['Docker', 'Git / GitHub', 'CI/CD', 'n8n'] },
  { code: 'G', label: 'AI engineering', items: ['Claude Code', 'GitHub Copilot', 'opencode', 'Ollama (experiment)'] },
  { code: 'H', label: 'Analysis', items: ['UML', 'Requirements gathering'] },
  { code: 'I', label: 'Spoken', items: ['Spanish (native)', 'English (B1–B2)'] },
];

// Set to true once public/Moises-Perez-CV.pdf exists.
const showCv = true;
---

<Layout>
  <!-- HEADER -->
  <header class="site-header">
    <div class="accent-rule"></div>
    <nav class="nav" aria-label="Primary">
      <a class="brand" href="#top">
        <span class="brand__name">Moisés Pérez</span>
        <span class="brand__domain">moisespaello.dev</span>
      </a>
      <div class="nav__links">
        <a class="nav__link" href="#about">Notes</a>
        <a class="nav__link" href="#work">Ledger</a>
        <a class="nav__link" href="#skills">Schedule</a>
        <a class="nav__link nav__link--cta" href="#contact">Sign-off</a>
      </div>
    </nav>
  </header>

  <main>
    <!-- HERO -->
    <section id="top" class="section section--hero" aria-labelledby="hero-title">
      <div class="hero__moon" aria-hidden="true">
        <svg viewBox="0 0 200 200">
          <defs>
            <mask id="crescent">
              <rect width="200" height="200" fill="black" />
              <circle cx="100" cy="100" r="84" fill="white" />
              <circle cx="132" cy="84" r="76" fill="black" />
            </mask>
          </defs>
          <rect width="200" height="200" fill="currentColor" mask="url(#crescent)" />
        </svg>
      </div>

      <div class="hero__meta meta">
        <span>Period: Jul 2025 — present &nbsp;·&nbsp; <span class="live">● in production</span></span>
      </div>

      <div class="hero__grid">
        <div class="hero__col" data-reveal>
          <h1 id="hero-title" class="hero__title">
            Moises Perez
          </h1>
          <p class="hero__intro">
            Sole developer with experience in the full lifecycle from requirements to production.
          </p>
          <div class="btn-row">
            <a class="btn btn--primary" href="https://github.com/moisesPAello" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 016 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z" /></svg>
              GitHub
            </a>
            <a class="btn btn--outline" href="https://www.linkedin.com/in/moises-paello" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 110-4.14 2.07 2.07 0 010 4.14zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z" /></svg>
              LinkedIn
            </a>
            <a class="btn btn--outline" href="mailto:moisesperezaello@gmail.com">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2" /><path d="m22 7-10 6L2 7" /></svg>
              Email
            </a>
            {showCv && (
              <a
                class="btn btn--ghost"
                href={`${import.meta.env.BASE_URL}moises-perez-cv.pdf`}
                download="Moises-Perez-CV.pdf"
              >
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                  <path d="M7 10l5 5 5-5" />
                  <path d="M12 15V3" />
                </svg>
                CV.pdf
              </a>
            )}
          </div>
        </div>

        <div class="hero__col" data-reveal>
          <div class="recon">
            <div class="recon__head">
              <strong>Conciliation</strong>
            </div>
            <div class="recon__cols">
              <div class="recon__col">
                <div class="recon__label">Manual workflow</div>
                <div class="recon__row">Crossing statements by hand</div>
                <div class="recon__row">Inconsistent ERP exports</div>
                <div class="recon__row">Ad-hoc AI prompting</div>
              </div>
              <div class="recon__col recon__col--out">
                <div class="recon__label">Working software</div>
                <div class="recon__row recon__row--done"><span>✓</span> Sella Cruce</div>
                <div class="recon__row recon__row--done"><span>✓</span> Financial module</div>
                <div class="recon__row recon__row--done"><span>✓</span> method-based-harness</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ABOUT / NOTES -->
    <section id="about" class="section" aria-labelledby="about-head">
      <div data-reveal>
        <p class="notes-body">
          I'm an Information Systems Engineering student at UNISON and the only developer at
          JGRP, building software since July 2025.
        </p>
        <p>
          <p class="notes-body">
            <span class="muted">
            I translate non-technical business requirements into working tools — full-stack,
            with a backend and data lean. The work is mostly listening first, then building the
            thing that makes the manual version disappear.
            </span>
          </p>
        </p>
      </div>
    </section>

    <!-- LEDGER OF WORK -->
    <section id="work" class="section section--work" aria-labelledby="work-head">
      <!-- 01 — Flagship: Sella Cruce -->
      <article class="entry entry--flagship" data-reveal>
        <div class="entry__bar">
          <span class="badge badge--flagship">Flagship</span>
          <span class="entry__status"><span class="dot"></span> In daily production use</span>
        </div>
        <div class="entry__body">
          <div class="entry__main">
            <h3 class="entry__title">Sella Cruce</h3>
            <p class="entry__sub">Bank-statement reconciliation</p>
            <p class="entry__desc">
              It cross-checks movements in bank PDF statements against an Excel of expected
              transactions and marks the matches — built directly from the by-hand process the
              team used before.
            </p>
            <div class="pae">
              <span class="pae__k">Problem</span>
              <span class="pae__v pae__v--ruled">Statements were reconciled against expected transactions manually, line by line.</span>
              <span class="pae__k">Approach</span>
              <span class="pae__v pae__v--ruled">Mapped the workflow with the team, then built a tool that parses the PDF, aligns it to the Excel, and surfaces matches and exceptions.</span>
              <span class="pae__k">Outcome</span>
              <span class="pae__v">In production at JGRP, used daily. Designed, built, deployed and maintained end to end by me.</span>
            </div>
            <div class="tags">
              <span class="tag">React</span>
              <span class="tag">TypeScript</span>
              <span class="tag">Python</span>
              <span class="tag">FastAPI</span>
              <span class="tag">Docker</span>
            </div>
            <p class="entry__lock">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
              Internal tool · handles client financial data — no public repo or demo
            </p>
          </div>

          <div class="mock">
            <div class="recon-mock">
              <div class="mock__head">
                <span>Reconciliation · sample</span>
                <span class="ok">142 / 150 matched</span>
              </div>
              <div class="mock__table">
                <div class="mock__row mock__row--head">
                  <span>Date</span><span>Movement</span><span class="amt">Amount</span><span class="st">Status</span>
                </div>
                <div class="mock__row mock__row--data">
                  <span class="num">03/04</span><span class="mv">Transfer ····4821</span><span class="amt">$12,400</span><span class="st">✓</span>
                </div>
                <div class="mock__row mock__row--data">
                  <span class="num">03/06</span><span class="mv">Deposit ····0937</span><span class="amt">$3,150</span><span class="st">✓</span>
                </div>
                <div class="mock__row mock__row--data mock__row--flag">
                  <span class="num">03/09</span><span class="mv">Fee ····1188</span><span class="amt">$280</span><span class="st st--flag">⚑</span>
                </div>
                <div class="mock__row mock__row--data">
                  <span class="num">03/11</span><span class="mv">Transfer ····5502</span><span class="amt">$8,900</span><span class="st">✓</span>
                </div>
                <div class="mock__row mock__row--total">
                  <span></span><span class="lbl">Reconciled</span><span class="amt">$24,450</span><span class="st">✓</span>
                </div>
              </div>
            </div>
            <p class="mock__cap">illustrative mockup — sanitized, not real client data</p>
          </div>
        </div>
      </article>

      <!-- 02 + 03 -->
      <div class="entries-grid">
        <article class="entry entry--sm" data-reveal>
          <div class="entry__bar">
            <span class="entry__cat">Case study · Data / ETL</span>
          </div>
          <div class="entry__inner">
            <h3 class="entry__title">Financial analysis module</h3>
            <p class="entry__sub">ERP normalization</p>
            <p class="entry__desc">
              A Python (pandas) module that normalizes inconsistent trial-balance exports from
              the CONTPAQi and Aspel accounting ERPs, with data-quality checks that keep results
              consistent across clients — extraction, parsing, normalization, validation.
            </p>
            <div class="tags">
              <span class="tag">Python</span>
              <span class="tag">pandas</span>
              <span class="tag">data quality</span>
            </div>
            <p class="entry__lock">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
              Internal tool at JGRP — no public repo
            </p>
          </div>
        </article>

        <article class="entry entry--sm" data-reveal>
          <div class="entry__bar">
            <span class="entry__cat entry__cat--accent">Open source · Early-stage</span>
          </div>
          <div class="entry__inner">
            <h3 class="entry__title">method-based-harness</h3>
            <p class="entry__sub">Methodology for AI coding</p>
            <p class="entry__desc">
              A Python CLI that applies software-engineering methodology to agentic coding
              harnesses — injecting "methodology packs" into a repo as native Claude Code files.
              An active exploration of <em>how</em> AI-assisted development should be structured.
              Runs in Claude Code today; opencode and Copilot support are planned.
            </p>
            <div class="tags">
              <span class="tag">Python</span>
              <span class="tag">CLI</span>
              <span class="tag">Claude Code</span>
            </div>
            <a class="entry__link" href="https://github.com/moisesPAello/method-based-harness" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 016 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z" /></svg>
              View repository →
            </a>
          </div>
        </article>
      </div>
    </section>

    <!-- SCHEDULE / SKILLS -->
    <section id="skills" class="section section--work" aria-labelledby="skills-head">
      <div class="section-head" data-reveal style="margin-bottom:8px;">
        <h2 id="skills-head" class="h-serif">Schedule of capabilities</h2>
        <span class="section-head__note">What I work with</span>
      </div>
      <div class="schedule" data-reveal>
        {skillGroups.map((g) => (
          <div class="sched-row">
            <div class="sched-key">
              <span class="sched-code">{g.code}</span>
              <span class="sched-label">{g.label}</span>
            </div>
            <div class="sched-items">
              {g.items.map((item) => <span class="chip">{item}</span>)}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- SIGN-OFF / CONTACT -->
    <section id="contact" class="section section--contact" aria-labelledby="contact-head">
      <div class="signoff" data-reveal>
        <div class="signoff__head">Sign-off</div>
        <div class="signoff__body">
          <h2 id="contact-head" class="signoff__title">Let's build something that lasts.</h2>
          <p class="signoff__lead">
            Open to full-stack, backend / Python roles
          </p>

          <div class="contact-list">
            <a class="contact-row" href="mailto:moisesperezaello@gmail.com">
              <span class="contact-row__k">Email</span>
              <span class="contact-row__line"></span>
              <span>moisesperezaello@gmail.com</span>
            </a>
            <a class="contact-row" href="https://github.com/moisesPAello" target="_blank" rel="noopener">
              <span class="contact-row__k">GitHub</span>
              <span class="contact-row__line"></span>
              <span>github.com/moisesPAello</span>
            </a>
            <a class="contact-row" href="https://www.linkedin.com/in/moises-paello/" target="_blank" rel="noopener">
              <span class="contact-row__k">LinkedIn</span>
              <span class="contact-row__line"></span>
              <span>/in/moises-perez</span>
            </a>
          </div>

          <div class="signature">
            <div>
              <div class="signature__name">Moisés Pérez</div>
              <div class="signature__sub">Reconciled &amp; signed</div>
            </div>
            <div class="signature__loc">Hermosillo, Sonora<br />Mexico</div>
          </div>
        </div>
      </div>

      <footer class="foot">
        <span>© 2025 Moisés Pérez · Hermosillo, MX</span>
        <span>moisespaello.dev · folio 001</span>
      </footer>
    </section>
  </main>
</Layout>
